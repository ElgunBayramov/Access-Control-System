<div class="loader-wrapper">
    <div class="loader-grid"></div>
    <div class="loader-scan"></div>

    <div class="loader-core">
        <div class="loader-ring ring-outer"></div>
        <div class="loader-ring ring-mid"></div>
        <div class="loader-ring ring-inner"></div>
        <div class="loader-glyph">&#10038;</div>
    </div>

    <div class="loader-text">
        <span class="loader-eyebrow">SYSTEM</span>
        <span class="loader-title">INITIALIZING SECURE SESSION</span>
        <div class="loader-status">
            <span class="status-dot"></span>
            <span class="status-label" id="loaderStatusLabel">ESTABLISHING HANDSHAKE...</span>
        </div>
        <div class="loader-bar-track">
            <div class="loader-bar-fill" id="loaderBarFill"></div>
        </div>
        <span class="loader-pct" id="loaderPct">0%</span>
    </div>

    <div class="loader-section section-left"></div>
    <div class="loader-section section-right"></div>
</div>

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Rajdhani:wght@400;500;600&display=swap');

    .loader-wrapper {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 9999;
        overflow: hidden;
        background: #050c14;
        font-family: 'Share Tech Mono', monospace;
    }

    .loader-wrapper .loader-section {
        position: fixed;
        top: 0;
        width: 51%;
        height: 100%;
        background: #050c14;
        z-index: 10;
    }

        .loader-wrapper .loader-section.section-left {
            left: 0;
            border-right: 1px solid rgba(0,255,180,0.15);
        }

        .loader-wrapper .loader-section.section-right {
            right: 0;
            border-left: 1px solid rgba(0,255,180,0.15);
        }

    .loader-grid {
        position: absolute;
        inset: 0;
        background-image: linear-gradient(rgba(0,255,180,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(0,255,180,0.04) 1px, transparent 1px);
        background-size: 44px 44px;
        z-index: 1;
        pointer-events: none;
    }

    .loader-scan {
        position: absolute;
        left: 0;
        right: 0;
        height: 2px;
        background: linear-gradient(90deg, transparent, rgba(0,255,180,0.5), transparent);
        animation: loader-scanline 2.4s linear infinite;
        z-index: 2;
        pointer-events: none;
    }

    @@keyframes loader-scanline {
        from

    {
        top: 0%;
    }

    to {
        top: 100%;
    }

    }

    .loader-core {
        position: fixed;
        left: 50%;
        top: 42%;
        width: 140px;
        height: 140px;
        margin: -70px 0 0 -70px;
        z-index: 11;
    }

    .loader-ring {
        position: absolute;
        inset: 0;
        border-radius: 50%;
        border: 1.5px solid transparent;
    }

    .ring-outer {
        border-top-color: #00ffb4;
        border-right-color: rgba(0,255,180,0.15);
        animation: loader-spin 1.8s linear infinite;
    }

    .ring-mid {
        inset: 14px;
        border-top-color: #00c899;
        animation: loader-spin-reverse 1.2s linear infinite;
    }

    .ring-inner {
        inset: 28px;
        border-top-color: rgba(0,255,180,0.6);
        animation: loader-spin 0.8s linear infinite;
    }

    .loader-glyph {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #00ffb4;
        font-size: 22px;
        text-shadow: 0 0 14px rgba(0,255,180,0.6);
        animation: loader-pulse 1.6s ease-in-out infinite;
    }

    @@keyframes loader-spin {
        0%

    {
        transform: rotate(0deg);
    }

    100% {
        transform: rotate(360deg);
    }

    }

    @@keyframes loader-spin-reverse {
        0%

    {
        transform: rotate(0deg);
    }

    100% {
        transform: rotate(-360deg);
    }

    }

    @@keyframes loader-pulse {
        0%, 100%

    {
        opacity: 0.5;
        transform: scale(0.92);
    }

    50% {
        opacity: 1;
        transform: scale(1.05);
    }

    }

    .loader-text {
        position: fixed;
        left: 50%;
        top: 58%;
        transform: translateX(-50%);
        width: 320px;
        text-align: center;
        z-index: 11;
    }

    .loader-eyebrow {
        display: block;
        font-size: 10px;
        letter-spacing: 4px;
        color: #00ffb4;
        text-transform: uppercase;
        margin-bottom: 6px;
    }

    .loader-title {
        display: block;
        font-family: 'Rajdhani', sans-serif;
        font-weight: 600;
        font-size: 15px;
        letter-spacing: 2px;
        color: #d8f0e8;
        text-transform: uppercase;
        margin-bottom: 14px;
    }

    .loader-status {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        margin-bottom: 14px;
    }

    .status-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: #00ffb4;
        animation: loader-blink 1.4s ease-in-out infinite;
    }

    @@keyframes loader-blink {
        0%, 100%

    {
        opacity: 1;
    }

    50% {
        opacity: 0.25;
    }

    }

    .status-label {
        font-size: 10px;
        letter-spacing: 2px;
        color: #4a8a6a;
        text-transform: uppercase;
    }

    .loader-bar-track {
        width: 100%;
        height: 4px;
        background: rgba(0,255,180,0.08);
        border: 1px solid rgba(0,255,180,0.2);
        border-radius: 2px;
        overflow: hidden;
        margin-bottom: 8px;
    }

    .loader-bar-fill {
        width: 0%;
        height: 100%;
        background: linear-gradient(90deg, #00c899, #00ffb4);
        box-shadow: 0 0 8px rgba(0,255,180,0.6);
        transition: width 0.2s ease-out;
    }

    .loader-pct {
        font-size: 10px;
        letter-spacing: 2px;
        color: #00ffb4;
    }

    .loaded .loader-wrapper {
        visibility: hidden;
        transition: visibility 0s 1s;
    }

        .loaded .loader-wrapper .loader-section.section-left {
            transform: translateX(-100%);
            transition: transform 0.7s 0.3s cubic-bezier(0.645, 0.045, 0.355, 1);
        }

        .loaded .loader-wrapper .loader-section.section-right {
            transform: translateX(100%);
            transition: transform 0.7s 0.3s cubic-bezier(0.645, 0.045, 0.355, 1);
        }

    .loaded .loader-core,
    .loaded .loader-text,
    .loaded .loader-grid,
    .loaded .loader-scan {
        opacity: 0;
        transition: opacity 0.3s ease-out;
    }

    @@media (max-width: 480px) {
        .loader-text

    {
        width: 84%;
    }

    }
</style>

<script>
    (function () {
        var fill = document.getElementById('loaderBarFill');
        var pct = document.getElementById('loaderPct');
        var label = document.getElementById('loaderStatusLabel');

        var messages = [
            'ESTABLISHING HANDSHAKE...',
            'VERIFYING CREDENTIALS...',
            'DECRYPTING SESSION...',
            'ACCESS GRANTED'
        ];

        var progress = 0;
        var step = setInterval(function () {
            progress += Math.random() * 18 + 7;
            if (progress >= 100) {
                progress = 100;
                clearInterval(step);
            }
            if (fill) fill.style.width = progress + '%';
            if (pct) pct.textContent = Math.floor(progress) + '%';
            if (label) {
                var idx = Math.min(messages.length - 1, Math.floor((progress / 100) * messages.length));
                label.textContent = messages[idx];
            }
        }, 160);

        function hidePreloader() {
            document.body.classList.add('loaded');
            setTimeout(function () {
                var preloader = document.querySelector('.loader-wrapper');
                if (preloader) preloader.style.display = 'none';
            }, 1100);
        }

        setTimeout(hidePreloader, 1400);
    })();
</script>
