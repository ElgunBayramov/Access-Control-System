@using Project.WebUI.Business.PermissionModule
@using Project.WebUI.Models.Entities
@model PermissionMultiModel
@{
    ViewData["Title"] = "My Access Requests";
}

<main class="table">
    <section class="table__header">
        <h1>A.C SYSTEM</h1>
        <a class="add" id="openModal" href="#">+ New Request</a>
        <div class="input-group">
            <input type="search" id="permSearch" placeholder="Search records...">
            <img src="~/images/search.png" alt="search">
        </div>
    </section>

    <section class="table__body">
        <table id="perm-table">
            <thead>
                <tr>
                    <th>First Name <span class="icon-arrow">&#x2193;</span></th>
                    <th>Last Name  <span class="icon-arrow">&#x2193;</span></th>
                    <th>Email      <span class="icon-arrow">&#x2193;</span></th>
                    <th>Date       <span class="icon-arrow">&#x2193;</span></th>
                    <th>Status     <span class="icon-arrow">&#x2193;</span></th>
                    <th>Duration   <span class="icon-arrow">&#x2193;</span></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model.Permission)
                {
                    <tr>
                        <td>@p.Name</td>
                        <td>@p.Surname</td>
                        <td>@p.Email</td>
                        <td>@p.Date?.ToString("dd.MM.yyyy HH:mm")</td>
                        @switch (p.Status)
                        {
                            case Status.Pending:
                                <td><p class="status pending">Pending</p></td>
                                break;
                            case Status.Rejected:
                                <td><p class="status cancelled">Rejected</p></td>
                                break;
                            case Status.Approved:
                                <td><p class="status delivered">Approved</p></td>
                                break;
                        }
                        <td><strong>@p.Duration</strong></td>
                    </tr>
                }
            </tbody>
        </table>
    </section>
</main>

<!-- New Request Modal -->
<div class="modal hidden" id="modal">
    <div class="modal-top">
        <button class="btn--close-modal" id="closeModal">&times;</button>
        <h2 class="modal__header">// New Access Request</h2>
    </div>
    <form asp-action="Index" asp-controller="Home"
          method="post" class="modal__form" id="permForm">

        <label>First Name:</label>
        <input placeholder="Enter first name" asp-for="@Model.CreateCommand.Name" type="text" required />

        <label>Last Name:</label>
        <input placeholder="Enter last name" asp-for="@Model.CreateCommand.Surname" type="text" required />

        <label>Email:</label>
        <input placeholder="visitor@example.com" asp-for="@Model.CreateCommand.Email" type="email" required />

        <label>Job Title:</label>
        <input placeholder="e.g. Engineer" asp-for="@Model.CreateCommand.Profession" type="text" />

        <label>Purpose:</label>
        <input placeholder="Reason for visit" asp-for="@Model.CreateCommand.Reason" type="text" required />

        <label>Visit Date:</label>
        <input asp-for="@Model.CreateCommand.Date" type="datetime-local" required />

        <label>Duration (hrs):</label>
        <input placeholder="e.g. 3" asp-for="@Model.CreateCommand.Duration" type="text" required />

        <button type="submit" class="btn">Submit &rarr;</button>
    </form>
</div>
<div class="overlay hidden" id="overlay"></div>

@section addjs {
    <script>

     
        // AJAX submit
        $("#permForm").submit(function (e) {
            e.preventDefault();
            $.ajax({
                url: "@Url.Action("Index", "Home")",
                type: "POST",
                data: $(this).serialize(),
                success: function () {
                    toastr.success("Request submitted — awaiting admin approval.");
                    $("#permForm")[0].reset();
                    modal.classList.add("hidden");
                    overlay.classList.add("hidden");
                    setTimeout(() => location.reload(), 1500);
                },
                error: function () {
                    toastr.error("An error occurred. Please try again.");
                }
            });
        });
    </script>
}

