@using Project.WebUI.Models.ViewModels
@model PagedViewModel<Profession>

<table class="ac-table">
    <thead>
        <tr>
            <th>#</th>
            <th>Name</th>
            <th class="operation">Operations</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Items)
        {
            <tr>
                <td style="color:var(--text-muted); font-size:10px;">@item.Id</td>
                <td>@item.Name</td>
                <td class="operation">
                    <a asp-action="edit" asp-route-id="@item.Id" class="btn-ac btn-ac-warning btn-ac-sm">
                        <i class="fa fa-pen"></i> Edit
                    </a>
                    <a asp-action="details" asp-route-id="@item.Id" class="btn-ac btn-ac-info btn-ac-sm">
                        <i class="fa fa-eye"></i> View
                    </a>
                    <a onclick="removeEntity(event,@item.Id,'@item.Name')" href="#" class="btn-ac btn-ac-danger btn-ac-sm">
                        <i class="fa fa-trash"></i> Delete
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>

@Model.GetPager(Url, "Index", area: "admin", paginateFunction: "goPage")