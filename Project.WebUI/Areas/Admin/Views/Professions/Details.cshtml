@model Profession
@{
    ViewData["Title"] = "Details";
}

<div class="page-header">
    <div>
        <h1><i class="fa fa-eye" style="margin-right:10px; font-size:16px;"></i>Profession Details</h1>
        <div class="page-breadcrumb">Admin &rsaquo; <a href="/Professions" style="color:var(--text-muted); text-decoration:none;">Professions</a> &rsaquo; <span>Details</span></div>
    </div>
</div>

<div class="ac-card" style="max-width:560px;">
    <div class="ac-card-header">
        <h4>Record Info</h4>
        <span style="font-size:9px; letter-spacing:2px; color:var(--green);">
            <i class="fa fa-circle" style="font-size:7px; margin-right:4px;"></i>READ ONLY
        </span>
    </div>
    <div class="ac-card-body">

        <div style="display:grid; grid-template-columns:120px 1fr; align-items:center; gap:12px; margin-bottom:14px; padding-bottom:14px; border-bottom:1px solid var(--border);">
            <span class="ac-label" style="margin:0;">ID</span>
            <span style="font-family:var(--mono); font-size:13px; color:var(--text-muted); letter-spacing:1px;">
                #@Model.Id
            </span>
        </div>

        <div style="display:grid; grid-template-columns:120px 1fr; align-items:center; gap:12px; margin-bottom:22px;">
            <span class="ac-label" style="margin:0;">Name</span>
            <span style="font-family:var(--mono); font-size:13px; color:var(--text-main); letter-spacing:1px;">
                @Model.Name
            </span>
        </div>

        <div style="display:flex; gap:10px;">
            <a asp-action="edit" asp-route-id="@Model.Id" class="btn-ac btn-ac-warning">
                <i class="fa fa-pen"></i> Edit
            </a>
            <a asp-action="index" class="btn-ac btn-ac-info">
                <i class="fa fa-arrow-left"></i> Go Back
            </a>
        </div>
    </div>
</div>