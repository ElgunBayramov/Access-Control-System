@using Project.WebUI.Models.Dtos.Roles
@using Project.WebUI.Models.Entities.Membership
@model ProjectUser
@{
    ViewData["Title"] = "Details";
}

<div class="page-header">
    <div>
        <h1><i class="fa fa-user" style="margin-right:10px; font-size:16px;"></i>User Details</h1>
        <div class="page-breadcrumb">Admin &rsaquo; <a href="/Users" style="color:var(--text-muted); text-decoration:none;">Users</a> &rsaquo; <span>Details</span></div>
    </div>
</div>

<div class="ac-card" style="max-width:720px;">
    <div class="ac-card-header">
        <h4>User Profile Info</h4>
        <span style="font-size:9px; letter-spacing:2px; color:var(--green);">
            <i class="fa fa-circle" style="font-size:7px; margin-right:4px;"></i>READ ONLY
        </span>
    </div>
    <div class="ac-card-body">

        <div style="display:grid; grid-template-columns:160px 1fr; align-items:center; gap:12px; margin-bottom:14px; padding-bottom:14px; border-bottom:1px solid var(--border);">
            <span class="ac-label" style="margin:0;">User ID</span>
            <span style="font-family:var(--mono); font-size:13px; color:var(--text-muted);">#@Model.Id</span>
        </div>

        <div style="display:grid; grid-template-columns:160px 1fr; align-items:center; gap:12px; margin-bottom:14px; padding-bottom:14px; border-bottom:1px solid var(--border);">
            <span class="ac-label" style="margin:0;">Full Name</span>
            <span style="font-size:14px; color:var(--text-main);">@Model.Name @Model.Surname</span>
        </div>

        <div style="display:grid; grid-template-columns:160px 1fr; align-items:center; gap:12px; margin-bottom:14px; padding-bottom:14px; border-bottom:1px solid var(--border);">
            <span class="ac-label" style="margin:0;">Email Address</span>
            <div>
                @if (Model.EmailConfirmed)
                {
                    <span class="badge badge-success" style="background-color:var(--green); color:white; padding:4px 10px; border-radius:4px; font-size:12px;">@Model.Email</span>
                }
                else
                {
                    <span class="badge badge-warning" style="background-color:var(--warn); color:white; padding:4px 10px; border-radius:4px; font-size:12px;">@Model.Email</span>
                }
            </div>
        </div>

        <div style="display:grid; grid-template-columns:160px 1fr; align-items:center; gap:12px; margin-bottom:14px; padding-bottom:14px; border-bottom:1px solid var(--border);">
            <span class="ac-label" style="margin:0;">Fin Code</span>
            <div>
                @if (Model.PhoneNumberConfirmed)
                {
                    <span class="badge badge-success" style="background-color:var(--green); color:white; padding:4px 10px; border-radius:4px; font-size:12px; font-family:var(--mono);">@Model.FinCode</span>
                }
                else
                {
                    <span class="badge badge-warning" style="background-color:var(--warn); color:white; padding:4px 10px; border-radius:4px; font-size:12px; font-family:var(--mono);">@Model.FinCode</span>
                }
            </div>
        </div>

        <div style="display:grid; grid-template-columns:160px 1fr; align-items:center; gap:12px; margin-bottom:14px; padding-bottom:14px; border-bottom:1px solid var(--border);">
            <span class="ac-label" style="margin:0;">Profession</span>
            <span style="font-size:14px; color:var(--text-main);">@ViewBag.professionName</span>
        </div>

        <div style="display:grid; grid-template-columns:160px 1fr; align-items:center; gap:12px; margin-bottom:22px; padding-bottom:14px; border-bottom:1px solid var(--border);">
            <span class="ac-label" style="margin:0;">Department</span>
            <span style="font-size:14px; color:var(--text-main);">@ViewBag.departmentName</span>
        </div>

        <div class="ac-form-group" style="margin-bottom: 2rem;">
            <div class="tab-control w-100" role="tabcontrol">
                <div class="tab-page" id="roles" aria-title="Rollar" selected>
                    <table class="ac-table">
                        <tbody>
                            @foreach (AvailableRole item in ViewBag.AvailableRoles)
                            {
                                <tr>
                                    <td style="border:none; padding: 8px 12px;">
                                        <input class="role-selector checkbox"
                                               data-role-name="@item.RoleName"
                                               data-user-id="@Model.Id"
                                               id="@item.RoleName"
                                               type="checkbox"
                                               @(item.Selected ? "checked" : "") />
                                        <label for="@item.RoleName">@item.RoleName</label>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="tab-page" id="principals" aria-title="Səlahiyyətlər">
                    <table class="ac-table">
                        <tbody>
                            @foreach (AvailablePrincipal item in ViewBag.AvailablePrincipals)
                            {
                                <tr>
                                    <td style="border:none; padding: 8px 12px;">
                                        <input class="principal-selector checkbox"
                                               data-principal-name="@item.PrincipalName"
                                               data-user-id="@Model.Id"
                                               id="@item.PrincipalName"
                                               type="checkbox"
                                               @(item.Selected ? "checked" : "") />
                                        <label for="@item.PrincipalName">@item.PrincipalName</label>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div style="display:flex; gap:10px;">
            <a asp-action="index" class="btn-ac btn-ac-info">
                <i class="fa fa-arrow-left"></i> Go Back
            </a>
        </div>
    </div>
</div>

@section addcss {
    <link rel="stylesheet" href="~/libs/tab-control/tab-control.css" />
    <style>
        input[type=checkbox].checkbox {
            display: none;
        }

            input[type=checkbox].checkbox + label {
                position: relative;
                padding-left: 25px;
                cursor: pointer;
            }

                input[type=checkbox].checkbox + label::before {
                    content: "";
                    font-size: 0.7em;
                    font-weight: 900;
                    font-family: "Font Awesome 5 Free";
                    position: absolute;
                    border: 1px solid #cccccc85;
                    width: 18px;
                    height: 18px;
                    border-radius: 2px;
                    top: 50%;
                    left: 0px;
                    transform: translateY(-50%);
                    text-align: center;
                    text-indent: 1px;
                    line-height: 1.7em;
                }

        input[type=checkbox]:checked.checkbox + label::before {
            content: "\f00c";
            color: #ffffff;
            background-color: teal;
            border-color: teal;
        }
    </style>
}

@section addjs {
    <script src="~/libs/tab-control/tab-control.js"></script>
    <script>
        $(document).ready(function() {
            $('.role-selector').change(function(e) {
                const body = $(e.currentTarget).data();
                body.selected = $(e.currentTarget).is(':checked');

                $.ajax({
                    type: "POST",
                    url: '@Url.Action("SetRole")',
                    data: body,
                    contentType: 'application/x-www-form-urlencoded',
                    success: function(response) {
                        if (response.error == false) {
                            toastr.success(response.message, "Uğur!");
                        } else {
                            $(e.currentTarget).prop('checked', !body.selected);
                            toastr.error(response.message, "Xəta!");
                        }
                    },
                    error: function(response) {
                        $(e.currentTarget).prop('checked', !body.selected);
                        toastr.error('Sistem xətası biraz sonra yenidən yoxlayın', "Xəta!");
                    }
                });
            });

            $('.principal-selector').change(function(e) {
                const body = $(e.currentTarget).data();
                body.selected = $(e.currentTarget).is(':checked');

                $.ajax({
                    type: "POST",
                    url: '@Url.Action("SetPrincipal")',
                    data: body,
                    contentType: 'application/x-www-form-urlencoded',
                    success: function(response) {
                        if (response.error == false) {
                            toastr.success(response.message, "Uğur!");
                        } else {
                            $(e.currentTarget).prop('checked', !body.selected);
                            toastr.error(response.message, "Xəta!");
                        }
                    },
                    error: function(response) {
                        $(e.currentTarget).prop('checked', !body.selected);
                        toastr.error('Sistem xətası biraz sonra yenidən yoxlayın', "Xəta!");
                    }
                });
            });
        });
    </script>
}