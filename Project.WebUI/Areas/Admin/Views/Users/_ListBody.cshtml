@using Project.WebUI.Models.Entities.Membership
@model PagedViewModel<ProjectUser>

<table class="ac-table">
    <thead>
        <tr>
            <th>#</th>
            <th>Name</th>
            <th>Surname</th>
            <th>Email</th>
            <th class="operation">Operations</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Items)
        {
            <tr>
                <td style="color:var(--text-muted); font-size:10px;">@item.Id</td>
                <td>@item.Name</td>
                <td>@item.Surname</td>
                <td>
                    @if (item.EmailConfirmed)
                    {
                        <span class="badge badge-success" style="background-color: var(--green); color: black; padding: 3px 8px; border-radius: 4px; font-size: 11px;">@item.Email</span>
                    }
                    else
                    {
                        <span class="badge badge-warning" style="background-color: var(--warn); color: black; padding: 3px 8px; border-radius: 4px; font-size: 11px;">@item.Email</span>
                    }
                </td>
                <td class="operation">
                    <a asp-action="details" asp-route-id="@item.Id" class="btn-ac btn-ac-info btn-ac-sm">
                        <i class="fa fa-eye"></i> View
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>

@Model.GetPager(Url, "Index", area: "admin", paginateFunction: "goPage")