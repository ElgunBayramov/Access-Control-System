@model Department
@{
    ViewData["Title"] = "Create";
}

<div class="page-header">
    <div>
        <h1><i class="fa fa-plus" style="margin-right:10px; font-size:16px;"></i>New Department</h1>
        <div class="page-breadcrumb">Admin &rsaquo; <a href="/Departments" style="color:var(--text-muted); text-decoration:none;">Departments</a> &rsaquo; <span>Create</span></div>
    </div>
</div>

<div class="ac-card" style="max-width:560px;">
    <div class="ac-card-header">
        <h4>Department Details</h4>
        <span style="font-size:9px; letter-spacing:2px; color:var(--text-muted);">NEW RECORD</span>
    </div>
    <div class="ac-card-body">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

            <div class="ac-form-group">
                <label class="ac-label" asp-for="Name">Department Name</label>
                <input class="ac-input" asp-for="Name" placeholder="Enter department name..." autocomplete="off">
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div style="display:flex; gap:10px; margin-top:1.4rem;">
                <button type="submit" class="btn-ac btn-ac-success">
                    <i class="fa fa-floppy-disk"></i> Save
                </button>
                <a asp-action="index" class="btn-ac btn-ac-info">
                    <i class="fa fa-arrow-left"></i> Go Back
                </a>
            </div>
        </form>
    </div>
</div>
